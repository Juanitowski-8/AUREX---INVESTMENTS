# =============================================================================
# Aurex Frontend — variables de entorno (ejemplo)
# =============================================================================
# Copia a `.env.local`:
#   cp .env.example .env.local
#
# REGLAS: no API keys ni secretos JWT aquí. Solo configuración pública.
# =============================================================================

# URL base del API Spring Boot (incluye /api). Sin barra final.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Fuente de datos: mock | api
# mock = datos locales (por defecto, no requiere backend)
# api  = fetch real contra Spring Boot
NEXT_PUBLIC_DATA_MODE=mock

# (Opcional, legacy) false equivale a modo api si DATA_MODE no está definido
# NEXT_PUBLIC_USE_MOCK_API=true
