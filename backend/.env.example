# Aurex Backend — environment variables (copy to .env for local tooling; Spring reads application.yml)

# Perfil Spring:
#   local  = H2 en memoria, sin Docker (recomendado para empezar)
#   default = PostgreSQL + Redis (requiere: docker compose up -d)
SPRING_PROFILES_ACTIVE=local

# Server
SERVER_PORT=8080

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aurex_db
POSTGRES_USER=aurex_user
POSTGRES_PASSWORD=aurex_password

# Spring datasource (optional overrides)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/aurex_db
SPRING_DATASOURCE_USERNAME=aurex_user
SPRING_DATASOURCE_PASSWORD=aurex_password

# JWT — use a long random secret in production (min 32 chars)
JWT_SECRET=change-me-use-openssl-rand-base64-32-in-production
JWT_EXPIRATION_MS=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Redis (market data cache; Render Key Value suele dar REDIS_URL)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
AUREX_MARKET_CACHE_ENABLED=true

# Market data provider: mock | coingecko (crypto en vivo desde CoinGecko)
AUREX_MARKET_PROVIDER=coingecko

# AI analysis LLM provider: mock | openai | anthropic
AUREX_AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_SECONDS=20
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
